# ═══════════════════════════════════════════
# CONTENT FACTORY — Environment Variables
# Скопируй этот файл в .env и заполни ключи
# ═══════════════════════════════════════════

# ── AI APIs ────────────────────────────────
OPENAI_API_KEY=sk-...          # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...   # https://console.anthropic.com/
ASSEMBLYAI_API_KEY=...         # https://www.assemblyai.com/ (опционально)
TWELVE_LABS_API_KEY=...        # https://api.twelvelabs.io/ (опционально, углублённый анализ)

# ── Video Generation ───────────────────────
HEYGEN_API_KEY=...             # https://app.heygen.com/settings → API
ELEVENLABS_API_KEY=...         # https://elevenlabs.io/app/settings/api-keys
RUNWAY_API_KEY=...             # https://app.runwayml.com/ (B-roll генерация)

# ── Discovery APIs ─────────────────────────
YOUTUBE_API_KEY=...            # https://console.cloud.google.com/ → YouTube Data API v3
APIFY_API_KEY=...              # https://console.apify.com/account/integrations (TikTok)
REDDIT_CLIENT_ID=...           # https://www.reddit.com/prefs/apps (опционально)
REDDIT_CLIENT_SECRET=...
REDDIT_USER_AGENT=ContentFactory/1.0 by YourUsername

# ── Storage ────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Queue ──────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Local paths ────────────────────────────
DOWNLOAD_DIR=./downloads
OUTPUT_DIR=./outputs

# ── Brand settings ─────────────────────────
NICHE_NAME=уходовая косметика Марья
NICHE_AUDIENCE=женщины 18-45 лет, интересующиеся уходом за кожей
BRAND_NAME=Марья
BRAND_TONE=тёплый, экспертный, без давления, вдохновляющий
